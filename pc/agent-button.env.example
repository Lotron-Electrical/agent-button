# agent-button PC poller config
# Copy this to your home folder as  ~/.agent-button.env  and fill in the values.
#   cp "pc/agent-button.env.example" "$HOME/.agent-button.env"

# Public URL of the Render relay (no trailing slash)
RELAY_URL=https://agent-button.onrender.com

# Must match the BUTTON_TOKEN env var set on the Render service
BUTTON_TOKEN=replace-with-your-secret

# Where spawned agents start by default (MSYS path). The phone "folder" field overrides this.
DEFAULT_CWD=/c/Users/Lloyd Gibbs

# Path to the spawn helper (MSYS path)
CLAUDE_TAB=/c/Users/Lloyd Gibbs/scripts/claude-tab.sh

# How often to poll the relay, ms
POLL_MS=4000
